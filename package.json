{
    "private": true,
    "scripts": {
        "dev": "vite build && npm run copy:media",
        "prod": "vite build --mode production && npm run copy:media",
        "watch": "vite build --watch",
        "copy:media": "mkdir -p _media && cp -R _site/media/. _media/"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.2",
        "autoprefixer": "^10.4.5",
        "hydefront": "^3.3.0",
        "postcss": "^8.5.12",
        "prettier": "2.6.0",
        "tailwindcss": "^3.0.24",
        "vite": "^5.4.19"
    }
}
