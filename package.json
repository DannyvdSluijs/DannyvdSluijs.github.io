{
    "private": true,
    "scripts": {
        "dev": "vite build && npm run copy:media",
        "prod": "vite build --mode production && npm run copy:media",
        "watch": "vite build --watch",
        "copy:media": "node -e \"const fs=require('node:fs');fs.mkdirSync('_media',{recursive:true});fs.cpSync('_site/media','_media',{recursive:true,force:true});\""
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.2",
        "autoprefixer": "^10.4.5",
        "hydefront": "^3.3.0",
        "postcss": "^8.5.12",
        "prettier": "2.6.0",
        "tailwindcss": "^3.0.24",
        "vite": "^5.4.19"
    }
}
